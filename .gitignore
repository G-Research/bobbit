.pi/
# Stray tsx transpile cache emitted when TMPDIR resolves to the literal string
# "undefined" (e.g. a shell with an unset/garbled temp env). Never commit it.
/undefined/
# .bobbit/config/ holds team-shared overrides (roles, tools, workflows) and SHOULD be committed.
# Per-machine runtime state lives in .bobbit/state/ and .bobbit/tmp/, both excluded below
# (state/ also via .bobbit/.gitignore for redundancy).
.bobbit/state/
.bobbit/tmp/
.bobbit/reports/
.e2e-pi*
.e2e-bobbit*
.e2e-fullstack*

# Bundled fd/rg binaries — populated by scripts/build-binaries.mjs at release
# time, NOT committed. Each sub-package bin/ stays tracked via .gitkeep.
binaries/binaries-*/bin/fd
binaries/binaries-*/bin/fd.exe
binaries/binaries-*/bin/rg
binaries/binaries-*/bin/rg.exe
.e2e-real-pi
.e2e-real-bobbit

# Generated esbuild bundles for file:// Playwright fixtures.
# Specs rebuild these on demand via tests/fixtures/build-bundle.ts or local beforeAll hooks.
tests/fixtures/*-bundle.js
tests/fixtures/*-bundle.css

.e2e-ui-pi
.e2e-ui-bobbit
tests/code-review-results.json
coverage/
concept/
ARCHIVE/
prompt_tmp.json
sessions_tmp.json
.e2e-test-inproc/
.e2e-inproc-*/
.e2e-resilience-*/
.bobbit-manual-integration-*/
.qa-test-state/

# Bundle profile output - regenerated by `npx vite build -c vite.profile.config.ts`
bundle-stats.html
bundle-stats.json
