#!/bin/sh
# graphify graph refresh — runs after `git checkout`/`git switch`, and also
# after `git worktree add` (git treats that as a checkout with flag=1 too —
# see the HAZARD note below).
#
# Only fires on an actual branch switch (git passes flag=1 for that; flag=0 is
# a plain file checkout, which we ignore). Keeps src/graphify-out/graph.json
# (gitignored) roughly in sync when hopping branches/worktrees.
# Opt in via `scripts/setup-githooks.sh` (sets core.hooksPath=.githooks).
#
# HAZARD this hook must guard against: `git worktree add` fires this hook in
# the *new* worktree. We routinely run 10+ concurrent lane worktrees, and
# they share the primary's graph via a symlink
# (src/graphify-out -> <primary>/src/graphify-out) — so a refresh fired from
# a worktree would rebuild the SHARED graph from that worktree's file state,
# potentially many times concurrently. Note that a graph-file-presence check
# is NOT a sufficient guard: the symlink makes graph.json look "present" in
# every worktree. scripts/graphify-refresh.sh therefore only proceeds in the
# PRIMARY checkout (git-dir == git-common-dir).
#
# Delegates to scripts/graphify-refresh.sh, which:
#   - no-ops silently if `graphify` isn't on PATH (other machines/CI unaffected)
#   - no-ops unless this is the PRIMARY checkout (see HAZARD above)
#   - coalesces via a lock (with stale-lock reclaim) so back-to-back checkouts
#     don't stack concurrent rebuilds
#   - runs detached at low priority so the checkout never blocks
#   - logs to src/graphify-out/graphify-update.log

BRANCH_SWITCH="$3"
[ "$BRANCH_SWITCH" = "1" ] || exit 0

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
"$repo_root/scripts/graphify-refresh.sh" --hook
