#!/bin/sh
# graphify graph refresh — runs after `git merge` / `git pull` completes.
#
# Keeps src/graphify-out/graph.json (gitignored) roughly in sync with the code
# so /orient and the graphify MCP don't drift too far from a merge window.
# Opt in via `scripts/setup-githooks.sh` (sets core.hooksPath=.githooks).
#
# Delegates to scripts/graphify-refresh.sh, which:
#   - no-ops silently if `graphify` isn't on PATH (other machines/CI unaffected)
#   - no-ops unless this is the PRIMARY checkout (git-dir == git-common-dir).
#     Lane worktrees share the primary's graph via a symlink
#     (src/graphify-out -> <primary>/src/graphify-out), so a refresh from a
#     worktree would rebuild the SHARED graph from that worktree's files —
#     and we routinely run 10+ lane worktrees concurrently. Refreshes must
#     only ever run from the primary.
#   - coalesces via a lock (with stale-lock reclaim) so back-to-back merges
#     don't stack concurrent rebuilds
#   - runs detached at low priority so `git merge`/`git pull` never blocks
#   - logs to src/graphify-out/graphify-update.log

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
"$repo_root/scripts/graphify-refresh.sh" --hook
