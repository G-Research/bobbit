# DO NOT REMOVE without reading this.
#
# `@earendil-works/pi-coding-agent@0.81.1` publishes an npm-shrinkwrap.json that
# resolves brace-expansion@5.0.7, fixing the targeted high advisory, but still
# pins known-vulnerable protobufjs@7.6.4 (moderate GHSA-j3f2-48v5-ccww). Bobbit's
# root overrides make the root/non-shrinkwrapped tree resolve protobufjs@7.6.5+
# and ws@8.21+, but root overrides do not penetrate a dependency-owned
# shrinkwrap. A packed consumer therefore retains the nested protobufjs@7.6.4.
# Compatibility may assert exactly that one moderate edge; release remains
# blocked until a compatible Pi patch publishes protobufjs@7.6.5+ there.
#
# On npm >=10 the legacy `shrinkwrap` key maps to `package-lock`, so this line
# means package-lock=false: it FREEZES the committed lockfile so a stray
# `npm install` cannot regenerate it from dependency-owned shrinkwraps.
# `npm ci` still installs from the committed lockfile as normal. Neither the
# committed lock nor a clean root `npm audit` proves the packed consumer secure.
#
# For controlled dependency/lock regeneration:
# 1. Stop gateway/vite/native-module holders. Back up this file outside the repo
#    with a failure trap, then temporarily move it out of the repository.
# 2. Delete the OLD installed
#    node_modules/@earendil-works/pi-coding-agent/npm-shrinkwrap.json.
# 3. Run `npm install --package-lock=true` while this file is out of the repo.
# 4. Restore ONLY this .npmrc; never restore the deleted old shrinkwrap.
# 5. Verify npm freshly extracted the selected-version coding-agent shrinkwrap,
#    all three Pi packages are aligned, every brace-expansion is 5.0.7+, the
#    root protobufjs is 7.6.5+, and root/non-shrinkwrapped ws is 8.21+.
# 6. Pack and install Bobbit in an empty project. For Pi 0.81.1, require exactly
#    the nested protobufjs@7.6.4 moderate above and no other audit finding. For a
#    later Pi patch, require every protobufjs to be 7.6.5+ and a zero audit.
shrinkwrap=false
