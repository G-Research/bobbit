# DO NOT REMOVE without reading this.
#
# `@earendil-works/pi-coding-agent` ships a bundled npm-shrinkwrap.json that
# pins vulnerable transitive deps (ws@8.20.1, protobufjs@7.5.9). Our root
# `overrides` (package.json) force secure versions (ws@8.21.0, protobufjs@7.6.4)
# EVERYWHERE except inside that bundled subtree — overrides do not penetrate a
# dependency's bundled shrinkwrap.
#
# On npm >=10 the legacy `shrinkwrap` key maps to `package-lock`, so this line
# means package-lock=false: it FREEZES the committed lockfile so a stray
# `npm install` cannot regenerate it with the vulnerable nested versions.
# `npm ci` still installs from the (secure) committed lockfile as normal.
#
# To intentionally update deps / the lockfile: temporarily (1) remove this file
# and (2) delete node_modules/@earendil-works/pi-coding-agent/npm-shrinkwrap.json,
# run `npm install`, verify no ws-8.20.1 / protobufjs-7.5.9 entries appear, then
# restore both. (This is how the current secure lockfile — and the tsx entry —
# were generated.)
shrinkwrap=false
